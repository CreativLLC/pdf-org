<apex:page StandardController="Opportunity" extensions="RateQuoteController" renderas="pdf">

<style>
.tablehead {
    border: 1px solid;
    background-color: #99C68E;
    font-weight: bold;
    font-size: 120%;
}
</style>

	<table width="700px">
		<tr>
			<td width="250px">
				<apex:image url="{!$Resource.OsibtysWebLogo}" width="150px" height="75px"/>
			</td>
			<td width="450px" align="right">
				&nbsp;
			</td>
		</tr>
		<tr>
			<td width="250px">
				<font color="#666666">11596 Marshall St.<br/>Westminster, CO 80020<br/>www.osibtys.com</font>
			</td>
			<td width="450px" align="right">		

			</td>
		</tr>
		<tr>
			<td width="700px" align="center" colspan="2">
				<br/>
				<h2>Rate Quote</h2>
				<h3>For SalesForce.com Consulting Services</h3>
				<h4>Prepared for {!opportunity.Account.Name}{!if(opportunity.Quote_Contact__c != '', ', Attn: ' & opportunity.Quote_Contact__r.Name, '')} </h4>
				
				<br/>&nbsp;
				<br/>&nbsp;
			</td>
		</tr>
		<tr>
			<td width="700px" align="left" colspan="2">
				The rates listed below are valid until {!validUntil} 
				<br/>&nbsp; 
			</td>
		</tr>
	</table>
	<table border="0" cellspacing="0" width="700px">
		<tr>
			<td><b><apex:outputLabel value="Product"/></b></td>
			<td><b><apex:outputLabel value="Description"/></b></td>
			<td><b><apex:outputLabel value="Price"/></b></td>
		</tr>
		<tr height="1px">
			<td bgcolor="#000000"></td>
			<td bgcolor="#000000"></td>
			<td bgcolor="#000000"></td>
		</tr>
		<apex:repeat value="{!quoteLineItems}" var="item">
			<tr>
				<td><apex:outputText value="{!item.value0}"/></td>
				<td><apex:outputText value="{!item.value1}"/></td>
				<td><apex:outputText value="{!item.value2}"/></td>
			</tr>
		</apex:repeat>
	</table>
	<apex:outputPanel rendered="{!showSupport}">
		<br/>
		<h3>Support Packages</h3>
		<hr/>
		<b>Would you like to save money and get on-call support or project work on an as-needed basis?</b><br/>
		Our support options allow you to pre-pay for hours at a discounted flat rate.  Support hours are good for 
		one year from the date of purchase, and may be applied to whatever you need in SalesForce.com: development, 
		troubleshooting, user support, etc...<br/><br/>
		<table border="0" cellspacing="0" width="700px">
			<tr>
				<td width="40%">Support options based on quoted rates:</td>
				<td width="30%"><b>Hours Purchased</b></td>
				<td width="30%"><b>Cost Per Hour</b></td>
			</tr>
			<tr height="1px">
				<td width="40%"></td>
				<td width="30%" bgcolor="#000000"></td>
				<td width="30%" bgcolor="#000000"></td>
			</tr>
			<tr>
				<td width="40%">&nbsp;</td>
				<td width="30%">20-99 Hours</td>
				<td width="30%">$
					<apex:outputText value="{0,number,#,##0.00}">
						<apex:param value="{!tier1Price}"/>
					</apex:outputText>
					/hr
				</td>
			</tr>
			<tr>
				<td width="40%">&nbsp;</td>
				<td width="30%">100-999 Hours</td>
				<td width="30%">$
					<apex:outputText value="{0,number,#,##0.00}">
						<apex:param value="{!tier2Price}"/>
					</apex:outputText>
					/hr
				</td>
			</tr>
			<tr>
				<td width="40%">&nbsp;</td>
				<td width="30%">1000+ Hours</td>
				<td width="30%">$
					<apex:outputText value="{0,number,#,##0.00}">
						<apex:param value="{!tier3Price}"/>
					</apex:outputText>
					/hr
				</td>
			</tr>
		</table> 
	</apex:outputPanel>
	<table width="700px">
		<tr>
			<td width="700px" align="left" colspan="2">&nbsp;<br/></td>
		</tr>
		<tr>
			<td width="700px" align="left" colspan="2">
				Thank you for your interest in Osibtys.  We appreciate the opportunity to do business with you.
				<br/><br/>Sincerely,<br/><br/>
				<!-- <br/>{!$User.FirstName}&nbsp;{!$User.LastName}
				<br/>{!$User.Title} -->
				<!-- 
				Jordan Howard<br/>
				Founder, Senior Design Specialist<br/>
				jordan.howard@osibtys.com<br/>
				303.819.2864
				-->
				Charles Howard<br/>
				Founder, Senior Developer<br/>
				charles.howard@osibtys.com<br/>
				303.532.6523
			</td>
		</tr>
	</table>
</apex:page>